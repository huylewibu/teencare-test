generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Parent {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String
  email     String    @unique
  students  Student[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Student {
  id                    Int                    @id @default(autoincrement())
  name                  String
  dob                   DateTime
  gender                String
  currentGrade          String                 @map("current_grade")
  parentId              Int                    @map("parent_id")
  parent                Parent                 @relation(fields: [parentId], references: [id], onDelete: Cascade)

  subscriptions         StudentSubscription[]
  registrations         ClassRegistration[]

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model Class {
  id                    Int                    @id @default(autoincrement())
  name                  String
  subject               String
  dayOfWeek             String                 @map("day_of_week")
  timeSlot              String                 @map("time_slot")
  teacherName           String                 @map("teacher_name")
  maxStudents           Int                    @map("max_students")

  registrations         ClassRegistration[]

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model SubscriptionPlan {
  id                    Int                    @id @default(autoincrement())
  name                  String                 @unique
  totalSessions         Int                    @map("total_sessions")
  durationDays          Int                    @map("duration_days")
  isActive              Boolean                @default(true) @map("is_active")

  subscriptions         StudentSubscription[]

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model StudentSubscription {
  id                    Int                    @id @default(autoincrement())
  studentId             Int                    @map("student_id")
  subscriptionPlanId    Int                    @map("subscription_plan_id")

  student               Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subscriptionPlan      SubscriptionPlan       @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)

  startDate             DateTime               @map("start_date")
  endDate               DateTime               @map("end_date")
  totalSessionsSnapshot Int                    @map("total_sessions_snapshot")
  usedSessions          Int                    @default(0) @map("used_sessions")

  registrations         ClassRegistration[]

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([studentId])
  @@index([subscriptionPlanId])
}

model ClassRegistration {
  id                    Int                    @id @default(autoincrement())
  classId               Int                    @map("class_id")
  studentId             Int                    @map("student_id")
  studentSubscriptionId Int?                   @map("student_subscription_id")
  nextOccurrenceAt      DateTime               @map("next_occurrence_at")

  class                 Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  student               Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentSubscription   StudentSubscription?   @relation(fields: [studentSubscriptionId], references: [id], onDelete: SetNull)

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@unique([classId, studentId])
  @@index([studentId, nextOccurrenceAt])
}